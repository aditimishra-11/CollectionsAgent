# ============================================================
# Mumbai Bank Collections Voicebot — environment variables
# Copy this file to .env and fill in real values.
# Never commit .env.
# ============================================================

# OpenAI — GPT-4.1 mini (bot) and GPT-4o (eval judge)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Sarvam AI — Saaras V3 (STT) and Bulbul V3 (TTS)
# Get from https://dashboard.sarvam.ai → API Keys
SARVAM_API_KEY=...

# Webhook sink for terminal outcomes
# Visit https://webhook.site, copy your unique URL, paste here
OUTCOME_WEBHOOK_URL=https://webhook.site/your-unique-id

# Model selection (override if needed)
LLM_MODEL=gpt-4.1-mini
JUDGE_MODEL=gpt-4o
